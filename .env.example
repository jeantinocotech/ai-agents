APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Google Analytics 4 (opcional — deixe vazio para desactivar)
GA_MEASUREMENT_ID=

# Atrás de Traefik/Coolify: confiar proxies para HTTPS/host correctos nas assinaturas de URL e pedidos (* = todos os proxies).
# TRUSTED_PROXIES=*


APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Marca (ficheiros dentro de /public — caminhos relativos, ex.: img/logo.svg)
# BRAND_FAVICON_SVG=favicon.svg
# BRAND_FAVICON_ICO=favicon.ico
# BRAND_LOGO_MAIN=img/gratoai_black.png
# BRAND_LOGO_GUEST=img/gratoai.png

# OpenAI (fallback quando o agente não tem api_key própria; necessário para sessões ChatKit)
OPENAI_API_KEY=

# Header beta do ChatKit — confirme na documentação atual se a API falhar
CHATKIT_OPENAI_BETA=chatkit_beta=v1

# Segredo para o Agent Builder (nó HTTP) ler/gravar CV e JD guardados — use um valor longo e aleatório
CHATKIT_INTEGRATION_API_SECRET=

# Alertas por email quando o ChatKit reporta erros no browser (lista separada por vírgula)
LOG_ALERT_MAIL=
# Intervalo mínimo entre emails iguais (mesmo utilizador + origem + mensagem), em segundos (21600 = 6 h)
CHATKIT_ALERT_THROTTLE_SECONDS=21600
# true = enviar só com APP_ENV=production
CHATKIT_ALERT_ONLY_PRODUCTION=true

# Limite de caracteres (Unicode) para corpo de CV / JD na biblioteca e na API ChatKit (predefinição + envio ao widget)
AGENT_DOCUMENT_MAX_CV_CHARS=20000
AGENT_DOCUMENT_MAX_JD_CHARS=60000

# Trilha de carreira: ID do agente (tabela agents) ChatKit ativo para criar CV em chat embutido na página do CV
# Avatar da Graça (caminho dentro de /public, ex.: img/graca-avatar.png)
# CAREER_TRAIL_MENTOR_AVATAR=img/graca-avatar.png
# Mínimo de caracteres (Unicode) no texto do CV de perfil para concluir o passo 1 da trilha (omissão: 400)
# CAREER_TRAIL_MIN_PROFILE_CV_CHARS=400

# Asaas API credentials
ASAAS_API_KEY=
# Mesmo valor do “authentication token” do webhook no painel Asaas (header asaas-access-token). Obrigatório em produção (403/401 nos webhooks se vazio ou diferente).
ASAAS_WEBHOOK_TOKEN=
# false / 0 para produção (API https://api.asaas.com); true apenas para sandbox.asaas.com
ASAAS_SANDBOX=true
# URL do webhook para copiar ao Asaas (POST, JSON): ${APP_URL}/api/cart/asaas/webhook — não usar /webhook/asaas

# LGPD / versões de documentos (incrementar ao alterar política ou termos para forçar novo aceite)
# LEGAL_PRIVACY_POLICY_VERSION=2026-05-15
# LEGAL_TERMS_VERSION=2026-05-15
# LEGAL_CONTACT_EMAIL=

# Senha: por omissão exige 12+ caracteres com maiúsculas, números e símbolo (fora do ambiente de testes Pest).
# Defina true só em desenvolvimento local se quiser voltar à regra mínima de 8 caracteres.
# PASSWORD_RELAX_RULES=false
