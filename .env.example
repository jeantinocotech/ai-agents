APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Atrás de Traefik/Coolify: confiar proxies para HTTPS/host correctos nas assinaturas de URL e pedidos (* = todos os proxies).
# TRUSTED_PROXIES=*


APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# OpenAI (fallback quando o agente não tem api_key própria; necessário para sessões ChatKit)
OPENAI_API_KEY=

# Header beta do ChatKit — confirme na documentação atual se a API falhar
CHATKIT_OPENAI_BETA=chatkit_beta=v1

# Segredo para o Agent Builder (nó HTTP) ler/gravar CV e JD guardados — use um valor longo e aleatório
CHATKIT_INTEGRATION_API_SECRET=

# Limite de caracteres (Unicode) para corpo de CV / JD na biblioteca e na API ChatKit (predefinição + envio ao widget)
AGENT_DOCUMENT_MAX_CV_CHARS=60000
AGENT_DOCUMENT_MAX_JD_CHARS=60000

# Trilha de carreira: ID do agente (tabela agents) ChatKit ativo para criar CV em chat embutido na página do CV
# Avatar da Graça (caminho dentro de /public, ex.: img/graca-avatar.png)
# CAREER_TRAIL_MENTOR_AVATAR=img/graca-avatar.png

# Asaas API credentials
ASAAS_API_KEY=
# Deve ser o MESMO authentication token definido ao criar o webhook no Asaas (header asaas-access-token). 32–255 caracteres — ver documentação Asaas.
ASAAS_WEBHOOK_TOKEN=
ASAAS_SANDBOX=true

# LGPD / versões de documentos (incrementar ao alterar política ou termos para forçar novo aceite)
# LEGAL_PRIVACY_POLICY_VERSION=2026-05-15
# LEGAL_TERMS_VERSION=2026-05-15
# LEGAL_CONTACT_EMAIL=

# Senha: por omissão exige 12+ caracteres com maiúsculas, números e símbolo (fora do ambiente de testes Pest).
# Defina true só em desenvolvimento local se quiser voltar à regra mínima de 8 caracteres.
# PASSWORD_RELAX_RULES=false
